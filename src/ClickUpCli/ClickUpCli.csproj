<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>clickup</AssemblyName>
    <RootNamespace>ClickUpCli</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\ClickUpClient\ClickUpClient.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- config.json は gitignore 対象だが、存在する場合は出力ディレクトリにコピーする -->
    <None Include="config.json" CopyToOutputDirectory="PreserveNewest" Condition="Exists('config.json')" />
    <None Include="config.sample.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
